---
import Layout from '../layouts/Layout.astro';
import ProductTabs from '../components/ProductTabs';
import {
  cases,
  company,
  featuredNewsSlugs,
  homepageFaq,
  newsArticles,
  productCategories,
  products
} from '../data/site';
import { buildFaqSchema } from '../lib/schema';

const featuredNews = newsArticles.filter((item) => featuredNewsSlugs.includes(item.slug));
const heroProduct = products.find((item) => item.slug === 'casting-grinding-robot-cell') ?? products[0];
const heroApplications = heroProduct.applications.slice(0, 3);
---

<Layout
  title="自动打磨机与铸件自动化解决方案"
  description="博恩科自动化专注铸件自动打磨机、数控自动抛光机、打磨机器人工作站及非标自动化定制，服务铸造与五金制造企业。"
  image="/media/hero-machine.jpg"
  schema={[buildFaqSchema(homepageFaq)]}
>
  <section class="hero">
    <div class="container">
      <div class="hero-stage">
        <div class="hero-stage-media" aria-hidden="true">
          <img src="/media/hero-machine.jpg" alt="博恩科自动打磨设备现场" />
        </div>
      </div>
      <div class="hero-stage-brief">
        <div class="hero-stage-copy">
          <span class="hero-stage-kicker">{heroProduct.categoryName}</span>
          <h1>铸件自动打磨与机器人工作站方案</h1>
          <p>围绕铸件、压铸件、浇冒口和复杂曲面修整，提供设备选型、试样联调与工位落地支持。</p>
        </div>
        <div class="hero-stage-actions">
          <div class="hero-actions">
            <a class="button" href={`/products/${heroProduct.slug}/`}>查看主推设备</a>
            <a class="button-secondary" href="/contact/">提交工件需求</a>
          </div>
          <div class="hero-stage-meta">
            {heroApplications.map((item) => (
              <span>{item}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-capability">
    <div class="container stats-grid capability-strip">
      <article class="stat">
        <strong>铸件打磨</strong>
        <span>覆盖去飞边、毛刺、分型线与浇冒口清理。</span>
      </article>
      <article class="stat">
        <strong>柔性工位</strong>
        <span>支持专机、机器人与工装联动的多种方案路径。</span>
      </article>
      <article class="stat">
        <strong>非标定制</strong>
        <span>根据工件、节拍和场地条件做结构与工艺配置。</span>
      </article>
      <article class="stat">
        <strong>本地沟通</strong>
        <span>莱州工厂支持现场看机、试样与交付前联调。</span>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container split-layout company-shell">
      <article class="section-block company-panel">
        <div class="section-header">
          <div>
            <h2 class="section-title">公司简介</h2>
            <p class="section-copy">
              原站内容的核心表述很明确：博恩科自动化长期聚焦铸件自动打磨机研发、生产、销售和服务，同时承接自动化加工与装配类非标专机。
            </p>
          </div>
          <a class="list-link" href="/about/">查看详情</a>
        </div>
        <ul class="bullets">
          {company.values.map((item) => <li>{item}</li>)}
        </ul>
        <div class="company-meta">
          <span>莱州本地工厂</span>
          <span>支持试样联调</span>
          <span>非标专机定制</span>
        </div>
      </article>
      <div class="detail-media company-media">
        <img src="/media/company-workshop.jpg" alt="博恩科工厂与设备环境" />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container section-block product-showcase-block">
      <div class="section-header">
        <div>
          <h2 class="section-title">产品方案</h2>
          <p class="section-copy">
            首页保留原站“数控自动抛光机 / 自动抛光机 / 自动打磨机 / 打磨机器人”四大分类，并改造成更适合比较与决策的展示方式。
          </p>
        </div>
        <a class="list-link" href="/products/">进入产品中心</a>
      </div>
      <ProductTabs client:load categories={productCategories} products={products} />
    </div>
  </section>

  <section class="section">
    <div class="container section-block process-shell">
      <div class="section-header">
        <div>
          <h2 class="section-title">项目推进方式</h2>
          <p class="section-copy">新版站点把“设备有什么”改成“如何落地”，更利于采购、技术和生产负责人快速判断项目可行性。</p>
        </div>
      </div>
      <div class="process-grid process-timeline">
        <article class="process-step">
          <span class="process-step-index">01</span>
          <h3>工件评估</h3>
          <p>确认材质、毛刺位置、加工余量、目标节拍和表面要求。</p>
        </article>
        <article class="process-step">
          <span class="process-step-index">02</span>
          <h3>方案匹配</h3>
          <p>在专机、数控机型与机器人工作站之间选择更合适的路径。</p>
        </article>
        <article class="process-step">
          <span class="process-step-index">03</span>
          <h3>试样与联调</h3>
          <p>围绕夹具、路径、耗材与防护除尘做试样验证和参数优化。</p>
        </article>
        <article class="process-step">
          <span class="process-step-index">04</span>
          <h3>交付与迭代</h3>
          <p>完成安装、培训和节拍爬坡，后续继续迭代工艺与维护机制。</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container section-block case-shell">
      <div class="section-header">
        <div>
          <h2 class="section-title">成功案例</h2>
          <p class="section-copy">原站案例栏目偏简短，新版将案例拆成“挑战 / 方案 / 结果”，便于客户快速类比自身工况。</p>
        </div>
        <a class="list-link" href="/cases/">查看全部案例</a>
      </div>
      <div class="case-grid">
        {cases.map((item) => (
          <article class="case-card">
            <img src={item.image} alt={item.name} loading="lazy" />
            <div class="case-card-body">
              <span class="card-tag">{item.industry}</span>
              <h3>{item.name}</h3>
              <p>{item.excerpt}</p>
              <a href={`/cases/${item.slug}/`}>查看案例拆解</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container section-block news-shell">
      <div class="section-header">
        <div>
          <h2 class="section-title">新闻动态</h2>
          <p class="section-copy">
            保留原站近年的实用文章内容，并按更清晰的短段落、清单和问题式结构重新整理，方便快速阅读。
          </p>
        </div>
        <a class="list-link" href="/news/">浏览全部文章</a>
      </div>
      <div class="news-grid">
        {featuredNews.map((item) => (
          <article class="news-card">
            <img src={item.image} alt={item.title} loading="lazy" />
            <div class="news-card-body">
              <span class="card-tag">
                {item.category} · {item.publishedAt}
              </span>
              <h3>{item.title}</h3>
              <p>{item.excerpt}</p>
              <a href={`/news/${item.slug}/`}>阅读文章</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container section-block faq-shell">
      <div class="section-header">
        <div>
          <h2 class="section-title">常见问题</h2>
          <p class="section-copy">把客户常问的设备、试样、交付和配套问题集中放在这里，方便初步了解方案边界。</p>
        </div>
      </div>
      <div class="faq-grid">
        {homepageFaq.map((item) => (
          <article class="faq-card">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container cta-strip">
      <div class="cta-copy">
        <span class="cta-kicker">方案沟通</span>
        <h2 class="detail-title">准备评估自动化打磨或抛光方案？</h2>
        <p class="section-copy">带上工件信息、当前人工节拍和目标良率，我们可以更快判断设备方向与试样方式。</p>
      </div>
      <div class="stack-actions cta-actions-panel">
        <a class="button" href="/contact/">联系博恩科</a>
        <a class="button-secondary" href="/videos/">查看视频中心</a>
      </div>
    </div>
  </section>
</Layout>
