---
import Layout from '../layouts/Layout.astro';
import ProductTabs from '../components/ProductTabs';
import {
  cases,
  company,
  featuredNewsSlugs,
  homepageFaq,
  newsArticles,
  productCategories,
  products
} from '../data/site';
import { buildFaqSchema } from '../lib/schema';

const featuredNews = newsArticles.filter((item) => featuredNewsSlugs.includes(item.slug));
const heroProduct = products.find((item) => item.slug === 'casting-grinding-robot-cell') ?? products[0];
const heroApplications = heroProduct.applications.slice(0, 3);
const capabilityItems = [
  { title: '铸件打磨', description: '覆盖去飞边、毛刺、分型线与浇冒口清理。' },
  { title: '柔性工位', description: '支持专机、机器人与工装联动的多种方案路径。' },
  { title: '非标定制', description: '根据工件、节拍和场地条件做结构与工艺配置。' },
  { title: '本地沟通', description: '莱州工厂支持现场看机、试样与交付前联调。' }
];
const companyTags = ['莱州本地工厂', '支持试样联调', '非标专机定制'];
const processSteps = [
  { title: '工件评估', description: '确认材质、毛刺位置、加工余量、目标节拍和表面要求。' },
  { title: '方案匹配', description: '在专机、数控机型与机器人工作站之间选择更合适的路径。' },
  { title: '试样与联调', description: '围绕夹具、路径、耗材与防护除尘做试样验证和参数优化。' },
  { title: '交付与迭代', description: '完成安装、培训和节拍爬坡，后续继续迭代工艺与维护机制。' }
];
---

<Layout
  title="自动打磨机与铸件自动化解决方案"
  description="博恩科自动化专注铸件自动打磨机、数控自动抛光机、打磨机器人工作站及非标自动化定制，服务铸造与五金制造企业。"
  image="/media/hero-machine.jpg"
  schema={[buildFaqSchema(homepageFaq)]}
>
  <section class="hero">
    <div class="container">
      <div class="hero-stage">
        <div class="hero-stage-media" aria-hidden="true">
          <div class="hero-stage-tech"></div>
          <div class="hero-stage-scan"></div>
          <img src="/media/hero-machine.jpg" alt="博恩科自动打磨设备现场" />
        </div>
      </div>
      <div class="hero-stage-brief">
        <div class="hero-stage-copy">
          <span class="hero-stage-kicker hero-seq hero-seq-1">{heroProduct.categoryName}</span>
          <h1 class="hero-seq hero-seq-2">铸件自动打磨与机器人工作站方案</h1>
          <p class="hero-seq hero-seq-3">围绕铸件、压铸件、浇冒口和复杂曲面修整，提供设备选型、试样联调与工位落地支持。</p>
        </div>
        <div class="hero-stage-actions">
          <div class="hero-actions hero-seq hero-seq-4">
            <a class="button" href={`/products/${heroProduct.slug}/`}>查看主推设备</a>
            <a class="button-secondary" href="/contact/">提交工件需求</a>
          </div>
          <div class="hero-stage-meta hero-seq hero-seq-5">
            {heroApplications.map((item) => (
              <span>{item}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-capability">
    <div class="container stats-grid capability-strip">
      {capabilityItems.map((item, index) => (
        <article class="stat" data-reveal="tile" style={`--reveal-index: ${index};`}>
          <strong>{item.title}</strong>
          <span>{item.description}</span>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="container split-layout company-shell">
      <article class="section-block company-panel" data-reveal="section" style="--reveal-index: 0;">
        <div class="section-header">
          <div>
            <h2 class="section-title">公司简介</h2>
            <p class="section-copy">
              博恩科自动化长期聚焦铸件自动打磨机研发、生产、销售和服务，同时承接自动化加工与装配类非标专机。
            </p>
          </div>
          <a class="list-link" href="/about/">查看详情</a>
        </div>
        <ul class="bullets">
          {company.values.map((item) => <li>{item}</li>)}
        </ul>
        <div class="company-meta">
          {companyTags.map((item) => (
            <span>{item}</span>
          ))}
        </div>
      </article>
      <div class="detail-media company-media" data-reveal="media" style="--reveal-index: 1;">
        <img src="/media/company-workshop.jpg" alt="博恩科工厂与设备环境" />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container section-block product-showcase-block" data-reveal="section">
      <div class="section-header">
        <div>
          <h2 class="section-title">产品方案</h2>
          <p class="section-copy">
            围绕数控自动抛光机、自动抛光机、自动打磨机与打磨机器人四大方向，提供更便于选型、比较和落地评估的产品方案。
          </p>
        </div>
        <a class="list-link" href="/products/">进入产品中心</a>
      </div>
      <ProductTabs client:load categories={productCategories} products={products} />
    </div>
  </section>

  <section class="section">
    <div class="container section-block process-shell" data-reveal="section">
      <div class="section-header">
        <div>
          <h2 class="section-title">项目推进方式</h2>
          <p class="section-copy">从工件评估、方案匹配到试样联调与交付爬坡，按照真实项目推进节奏组织信息，方便采购、技术和生产负责人快速判断可行性。</p>
        </div>
      </div>
      <div class="process-grid process-timeline">
        {processSteps.map((item, index) => (
          <article class="process-step" data-reveal="tile" style={`--reveal-index: ${index};`}>
            <span class="process-step-index">{String(index + 1).padStart(2, '0')}</span>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container section-block case-shell" data-reveal="section">
      <div class="section-header">
        <div>
          <h2 class="section-title">成功案例</h2>
          <p class="section-copy">围绕典型工况梳理挑战、方案与结果，帮助客户快速类比自身产线需求。</p>
        </div>
        <a class="list-link" href="/cases/">查看全部案例</a>
      </div>
      <div class="case-grid">
        {cases.map((item, index) => (
          <article class="case-card" data-reveal="tile" style={`--reveal-index: ${index};`}>
            <img src={item.image} alt={item.name} loading="lazy" />
            <div class="case-card-body">
              <span class="card-tag">{item.industry}</span>
              <h3>{item.name}</h3>
              <p>{item.excerpt}</p>
              <a href={`/cases/${item.slug}/`}>查看案例拆解</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container section-block news-shell" data-reveal="section">
      <div class="section-header">
        <div>
          <h2 class="section-title">新闻动态</h2>
          <p class="section-copy">
            聚焦设备应用、使用维护和工艺经验，方便快速了解自动打磨与抛光方案的现场要点。
          </p>
        </div>
        <a class="list-link" href="/news/">浏览全部文章</a>
      </div>
      <div class="news-grid">
        {featuredNews.map((item, index) => (
          <article class="news-card" data-reveal="tile" style={`--reveal-index: ${index};`}>
            <img src={item.image} alt={item.title} loading="lazy" />
            <div class="news-card-body">
              <span class="card-tag">
                {item.category} · {item.publishedAt}
              </span>
              <h3>{item.title}</h3>
              <p>{item.excerpt}</p>
              <a href={`/news/${item.slug}/`}>阅读文章</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container section-block faq-shell" data-reveal="section">
      <div class="section-header">
        <div>
          <h2 class="section-title">常见问题</h2>
          <p class="section-copy">把客户常问的设备、试样、交付和配套问题集中放在这里，方便初步了解方案边界。</p>
        </div>
      </div>
      <div class="faq-grid">
        {homepageFaq.map((item, index) => (
          <article class="faq-card" data-reveal="tile" style={`--reveal-index: ${index};`}>
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container cta-strip" data-reveal="section">
      <div class="cta-copy">
        <span class="cta-kicker">方案沟通</span>
        <h2 class="detail-title">准备评估自动化打磨或抛光方案？</h2>
        <p class="section-copy">带上工件信息、当前人工节拍和目标良率，我们可以更快判断设备方向与试样方式。</p>
      </div>
      <div class="stack-actions cta-actions-panel">
        <a class="button" href="/contact/">联系博恩科</a>
        <a class="button-secondary" href="/videos/">查看视频中心</a>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const initMotion = () => {
        const items = Array.from(document.querySelectorAll('[data-reveal]'));
        if (!items.length) return;

        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const threshold = window.innerHeight * 0.9;

        for (const item of items) {
          const rect = item.getBoundingClientRect();
          if (rect.top <= threshold) {
            item.classList.add('is-visible');
          }
        }

        document.documentElement.classList.add('motion-enhanced');

        if (reduced) {
          for (const item of items) item.classList.add('is-visible');
          return;
        }

        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (!entry.isIntersecting) continue;
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          },
          {
            threshold: 0.18,
            rootMargin: '0px 0px -10% 0px'
          }
        );

        for (const item of items) {
          if (item.classList.contains('is-visible')) continue;
          observer.observe(item);
        }
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initMotion, { once: true });
      } else {
        initMotion();
      }
    })();
  </script>
</Layout>
